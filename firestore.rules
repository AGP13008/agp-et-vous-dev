rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function isAdmin(){
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    match /publicNews/{id} { allow read: if true; allow write: if isAdmin(); }
    match /publicActivities/{id} { allow read: if true; allow write: if isAdmin(); }
    match /classifieds/{id} { allow read: if signedIn(); allow create: if signedIn(); allow update, delete: if isAdmin() || request.auth.uid == resource.data.authorUid; }
    match /aid/{id} { allow read: if signedIn(); allow create: if signedIn(); allow update, delete: if isAdmin() || request.auth.uid == resource.data.authorUid; }
    match /artisans/{id} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /privateInfo/{id} { allow read: if signedIn(); allow write: if isAdmin(); }
    match /users/{uid} { allow read: if signedIn() && (request.auth.uid == uid || isAdmin()); allow write: if isAdmin(); }
  }
}