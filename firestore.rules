rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasProfile() { return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isMember() { return hasProfile() && profile().role in ['member', 'admin']; }
    function isAdmin() { return hasProfile() && profile().role == 'admin'; }
    function ownPendingSubmission() {
      return isMember()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'pending';
    }
    function ownsResource() {
      return isMember() && resource.data.authorUid == request.auth.uid;
    }
    function safeOwnerResubmission() {
      return ownsResource()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.status == 'pending';
    }

    match /publicActivities/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }
    match /classifieds/{id} {
      allow read: if isMember() && (resource.data.status == 'published' || resource.data.authorUid == request.auth.uid || isAdmin());
      allow create: if ownPendingSubmission();
      allow update: if isAdmin() || safeOwnerResubmission();
      allow delete: if isAdmin() || ownsResource();
    }
    match /aid/{id} {
      allow read: if isMember() && (resource.data.status == 'published' || resource.data.authorUid == request.auth.uid || isAdmin());
      allow create: if ownPendingSubmission();
      allow update: if isAdmin()
        || safeOwnerResubmission()
        || (ownsResource()
          && resource.data.status == 'published'
          && request.resource.data.status == 'published'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['progress', 'updatedAt']));
      allow delete: if isAdmin() || ownsResource();
    }
    match /artisans/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }
    match /magazines/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }
    match /photoAlbums/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }
    match /magazinePages/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }
    match /albumPhotos/{id} {
      allow read: if isMember();
      allow write: if isAdmin();
    }
    match /activityRegistrations/{id} {
      allow read: if isAdmin() || (isMember() && resource.data.userUid == request.auth.uid);
      allow create: if isMember()
        && request.resource.data.userUid == request.auth.uid;
      allow delete: if isAdmin() || (isMember() && resource.data.userUid == request.auth.uid);
      allow update: if false;
    }
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'pending';
      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'mobile', 'email', 'updatedAt'
          ]));
      allow delete: if isAdmin();
    }
    match /publicNews/{id} { allow read, write: if false; }
    match /privateInfo/{id} { allow read, write: if false; }
  }
}
